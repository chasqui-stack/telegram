# Server
PORT=8001

# Telegram Bot API
# Get a bot token from @BotFather (https://t.me/BotFather) — see
# https://github.com/chasqui-stack/chasqui/blob/main/docs/TELEGRAM-SETUP.md
TELEGRAM_BOT_TOKEN=your_bot_token
# Any random string — you pass it to setWebhook and Telegram echoes it back in
# the X-Telegram-Bot-Api-Secret-Token header on every webhook call.
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret
# Dev only (ngrok); when set, the gateway registers the webhook on startup.
# TELEGRAM_WEBHOOK_URL=https://your-ngrok-url.ngrok.io/webhook

# Chasqui core
CORE_URL=http://localhost:8090
INTERNAL_API_KEY=

# User-facing fallbacks — English defaults; set them in your users' language.
# (The agent localizes itself via the system prompt; these only fire when the
# core is unreachable or the message type isn't handled.)
# ERROR_REPLY=Sorry, we hit a technical issue. Please try again in a few minutes.
# UNSUPPORTED_REPLY=For now I only handle text, audio, images and buttons. Send me a message and I'll be glad to help.

# Sentry (optional)
SENTRY_DSN=
